{
  "name": "printease-desktop-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main.js",
  "files": [
    "main.js",
    "preload.cjs",
    "agent/",
    "config/",
    "printer/",
    "local/",
    "package.json"
  ],
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis",
    "verify:package": "node scripts/verify-package-files.cjs",
    "dist:linux": "electron-builder --linux AppImage deb",
    "dist:appimage": "electron-builder --linux AppImage"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "productName": "PrintEase Desktop",
  "description": "PrintEase Desktop app and local printer agent",
  "build": {
    "appId": "com.printease.desktop",
    "productName": "PrintEase Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.cjs",
      "package.json",
      "agent/**/*",
      "config/**/*",
      "ipc/**/*",
      "printer/**/*",
      "local/**/*",
      "updater.js",
      "scripts/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend-dist",
        "to": "frontend-dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "PrintEase-Desktop-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "adityasomde",
        "repo": "printease-desk"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "artifactName": "PrintEase-Desktop-${version}-${arch}.${ext}",
      "maintainer": "PrintEase <support@printease.local>"
    },
    "appImage": {
      "artifactName": "PrintEase-Desktop-${version}-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "PrintEase-Desktop-${version}-${arch}.${ext}"
    }
  },
  "author": "PrintEase"
}
