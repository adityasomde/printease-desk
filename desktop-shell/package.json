{
  "name": "printease-desktop-shell",
  "version": "0.1.73",
  "private": true,
  "type": "module",
  "packageManager": "traversal@0.0.0",
  "main": "main.js",
  "files": [
    "main.js",
    "preload.cjs",
    "agent/",
    "config/",
    "security/",
    "printer/",
    "local/",
    "assets/",
    "package.json"
  ],
  "scripts": {
    "dev": "node scripts/run-electron-app.cjs",
    "start": "node scripts/run-electron-app.cjs",
    "pack": "npm_config_loglevel=error node scripts/run-electron-builder.cjs --dir",
    "dist": "npm_config_loglevel=error node scripts/run-electron-builder.cjs --publish never",
    "dist:win": "node scripts/download-libreoffice.js --platform win32 && cross-env PE_TARGET_PLATFORM=win32 electron-builder --config electron-builder.win.yml --win nsis --publish never",
    "dist:win:local-libreoffice": "node scripts/download-libreoffice.js --platform win32 --copy-local && cross-env PE_TARGET_PLATFORM=win32 electron-builder --config electron-builder.win.yml --win nsis --publish never",
    "verify:package": "node scripts/verify-package-files.cjs",
    "dist:linux": "node scripts/download-libreoffice.js --copy-local --platform linux && cross-env PE_TARGET_PLATFORM=linux npm_config_loglevel=error electron-builder --config electron-builder.linux.yml --linux AppImage deb --publish never && node scripts/create-linux-blockmaps.cjs",
    "dist:appimage": "node scripts/download-libreoffice.js --copy-local --platform linux && cross-env PE_TARGET_PLATFORM=linux npm_config_loglevel=error electron-builder --config electron-builder.linux.yml --linux AppImage --publish never && node scripts/create-linux-blockmaps.cjs",
    "download:libreoffice": "node scripts/download-libreoffice.js",
    "download:libreoffice:linux": "node scripts/download-libreoffice.js --platform linux --copy-local",
    "download:libreoffice:win": "node scripts/download-libreoffice.js --platform win32",
    "download:libreoffice:win:local": "node scripts/download-libreoffice.js --platform win32 --copy-local",
    "release:gui": "node tools/release-gui/start.cjs"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "33.0.0",
    "electron-builder": "^26.8.1",
    "tmp": "^0.2.7"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "pdf-lib": "^1.17.1"
  },
  "productName": "PrintEase Desktop",
  "description": "PrintEase Desktop app and local printer agent",
  "homepage": "https://github.com/adityasomde/printease-desk",
  "build": {
    "appId": "com.printease.desktop",
    "productName": "PrintEase Desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.cjs",
      "package.json",
      "agent/**/*",
      "config/**/*",
      "security/**/*",
      "ipc/**/*",
      "printer/**/*",
      "local/**/*",
      "updater.js",
      "scripts/**/*",
      "assets/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend-dist",
        "to": "frontend-dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "vendor/win/SumatraPDF.exe",
        "to": "vendor/win/SumatraPDF.exe"
      },
      {
        "from": "vendor/win/THIRD_PARTY_NOTICES.md",
        "to": "vendor/win/THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "vendor/libreoffice",
        "to": "vendor/libreoffice",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "artifactName": "PrintEase-Desktop-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PrintEase Desktop",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "adityasomde",
        "repo": "printease-desk"
      }
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "artifactName": "PrintEase-Desktop-${version}-${arch}.${ext}",
      "maintainer": "PrintEase <support@printease.local>"
    },
    "appImage": {
      "artifactName": "PrintEase-Desktop-${version}-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "PrintEase-Desktop-${version}-${arch}.${ext}"
    }
  },
  "author": "PrintEase"
}
